# StockFlow Backend — zmienne środowiskowe
# Skopiuj do .env i uzupełnij wartości
# NIGDY nie commituj .env do repozytorium!

# ── Środowisko ────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production

# ── Baza danych ───────────────────────────────────────────────────────
# Supabase (produkcja):
# DATABASE_URL=postgresql://postgres:[HASŁO]@db.[PROJEKT].supabase.co:5432/postgres
#
# SQLite (dev — domyślnie gdy brak DATABASE_URL):
# DB_PATH=./stock_app.db

# ── Bezpieczeństwo ────────────────────────────────────────────────────
# Wygeneruj: openssl rand -hex 32
SECRET_KEY=zmien-mnie-na-losowy-klucz-min-32-znaki-xxxxxxxxxxxxxxxx

# Token JWT ważny przez N minut (domyślnie 1440 = 24h)
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS ─────────────────────────────────────────────────────────────
# W produkcji podaj domenę Next.js (oddzielone przecinkami)
ALLOWED_ORIGINS=http://localhost:3000,https://twoja-domena.vercel.app

# ── API zewnętrzne ────────────────────────────────────────────────────
# Alpaca Markets (opcjonalne — live ceny akcji USA)
# ALPACA_API_KEY=twoj-klucz
# ALPACA_SECRET_KEY=twoj-sekret

# Binance i CoinGecko są publiczne — nie wymagają klucza

# ── Cache TTL (sekundy) ───────────────────────────────────────────────
# ANALYSIS_CACHE_TTL=900    # 15 min
# SCAN_CACHE_TTL=3600       # 1h

# ── Yahoo Finance rate limit ──────────────────────────────────────────
# YF_RATE_LIMIT=4           # req/s (zalecane dla współdzielonego IP)

# ── Logi ─────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
