# Szablon sekretów dla Streamlit Cloud
# ======================================
# NA STREAMLIT CLOUD: wklej zawartość poniżej w
#   Settings → Secrets (NIE commituj prawdziwych wartości do repo!).
#
# Lokalnie: skopiuj ten plik do .streamlit/secrets.toml i uzupełnij.

# Klucz do szyfrowania tokenów/haseł w bazie (Fernet).
# Wygeneruj raz poleceniem:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY = "tu-wklej-wygenerowany-klucz"

# Tempo zapytań do Yahoo Finance (req/s). Zalecane 4 na Streamlit Cloud
# (współdzielone IP wielu użytkowników).
YF_RATE_LIMIT = "4"

# OPCJONALNE: Alpaca Markets - darmowy klucz API dla danych live (akcje USA).
# Zarejestruj się na alpaca.markets (paper trading, bez karty kredytowej),
# wygeneruj klucz w panelu API Keys. Bez tych dwóch wartości aplikacja
# nadal działa normalnie - po prostu bez dodatkowego źródła live dla USA
# (Yahoo Finance pozostaje głównym źródłem, ~15 min opóźnienia).
# ALPACA_API_KEY = "tu-wklej-klucz"
# ALPACA_SECRET_KEY = "tu-wklej-sekret"
